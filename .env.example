# Xiaomi Music Agent example config. Copy to .env.local and fill locally.
# LLM is optional: alias-table and exact playlist matching do NOT need it.
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace_me
MODEL_NAME=replace_me
# Optional: used for semantic playlist matching. Defaults to OPENAI_BASE_URL/OPENAI_API_KEY.
# Set these separately when your chat provider does not support /embeddings.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=replace_me
EMBEDDING_MODEL_NAME=text-embedding-3-small
# If nearest local playlist cosine score is below this, Agent falls back to online search/LLM.
PLAYLIST_EMBEDDING_THRESHOLD=0.45

XIAOMI_MUSIC_ROOT=$HOME/xiaomi-music
XIAOMUSIC_PORT=8090
MUSIC_AGENT_PORT=8765
NETEASE_CDP_PORT=9222
MUSIC_AGENT_URL=http://127.0.0.1:8765

# Fill after xiaomusic login/config.
XIAOMUSIC_HOSTNAME=http://YOUR_MAC_LAN_IP
XIAOMUSIC_MI_DID=YOUR_XIAOMI_DEVICE_DID
MUSIC_OUTPUT_DEVICE=Xiaomi Sound-4567
MUSIC_BLUETOOTH_DEVICE=Xiaomi Sound-4567
